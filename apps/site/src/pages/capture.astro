---
// Offline capture page — renders one recipe fullscreen on black for the
// gen-previews tool (Playwright records the viewport to webm). ?slug=<slug>.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Pylinka capture</title>
  </head>
  <body style="margin:0;background:#000;overflow:hidden">
    <canvas id="c" style="display:block;width:100vw;height:100vh"></canvas>
    <script>
      import { createParticles, type AtlasOptions, type ParticlesHandle } from '@pylinka/core/webgl';
      import type { System } from '@pylinka/graph';
      import { RECIPES } from '../recipes/data';

      (window as unknown as { __slugs: string[] }).__slugs = RECIPES.map((r) => r.slug);

      const slug = new URLSearchParams(location.search).get('slug');
      const canvas = document.getElementById('c') as HTMLCanvasElement;
      const recipe = RECIPES.find((r) => r.slug === slug);

      const loadImage = (url: string) =>
        new Promise<HTMLImageElement>((res, rej) => {
          const i = new Image();
          i.onload = () => res(i);
          i.onerror = rej;
          i.src = url;
        });

      async function boot() {
        if (!recipe) return;
        canvas.width = canvas.clientWidth;
        canvas.height = canvas.clientHeight;

        const systems = recipe.project.systems.filter((s) => s.enabled);
        const ids = new Set(systems.map((s) => s.id));
        const links = recipe.subEmitters ?? {};
        const parentOf = (id: string) => {
          const p = links[id];
          return p && ids.has(p) ? p : undefined;
        };
        // atlas for a system: per-system map, or the legacy single atlas on systems[0]
        const atlasFor = async (sys: System): Promise<AtlasOptions | undefined> => {
          const a = recipe.systemAtlases?.[sys.id] ?? (recipe.atlas && sys.id === recipe.project.systems[0]!.id ? recipe.atlas : undefined);
          if (!a) return undefined;
          try {
            return { ...a, image: await loadImage(a.url) };
          } catch {
            return undefined;
          }
        };
        // topological order: a system after its parent
        const ordered: System[] = [];
        const placed = new Set<string>();
        let guard = systems.length + 1;
        while (ordered.length < systems.length && guard-- > 0)
          for (const s of systems) {
            if (placed.has(s.id)) continue;
            const par = parentOf(s.id);
            if (!par || placed.has(par)) { ordered.push(s); placed.add(s.id); }
          }
        for (const s of systems) if (!placed.has(s.id)) ordered.push(s);

        const byId = new Map<string, ParticlesHandle>();
        const handles: ParticlesHandle[] = [];
        for (const sys of ordered) {
          const atlas = await atlasFor(sys);
          const par = parentOf(sys.id);
          const subParent = par ? byId.get(par) : undefined;
          const fx = createParticles(canvas, recipe.project, {
            systemName: sys.name,
            zoom: 1.6,
            sizeScale: 2.2,
            ...(atlas ? { atlas } : {}),
            ...(subParent ? { subParent } : {}),
          });
          fx.autoClear = handles.length === 0;
          byId.set(sys.id, fx);
          handles.push(fx);
        }

        const cx = canvas.width / 2;
        const cy = canvas.height / 2;
        let t = 0;
        function frame() {
          t += 1 / 60;
          let ex = cx, ey = cy;
          if (recipe!.group === 'trails' || recipe!.group === 'combo') {
            const r = Math.min(canvas.width, canvas.height) * (recipe!.group === 'combo' ? 0.14 : 0.26);
            ex = cx + Math.cos(t * 1.5) * r;
            ey = cy + Math.sin(t * 1.5) * r;
          } else if (recipe!.group === 'ambient') {
            ex = cx; ey = canvas.height * 0.12;
          }
          for (const fx of handles) { fx.setEmitter(ex, ey); fx.update(1 / 60); }
          requestAnimationFrame(frame);
        }
        requestAnimationFrame(frame);
        (window as unknown as { __ready: boolean }).__ready = true;
      }
      boot();
    </script>
  </body>
</html>
