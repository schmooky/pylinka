---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pylinka — Playground</title>
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%E2%9C%A8%3C/text%3E%3C/svg%3E" />
  </head>
  <body>
    <main class="mx-auto max-w-4xl px-5 py-10">
      <div class="mb-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <span class="grid h-6 w-6 place-items-center rounded-md border border-border bg-card text-[11px]">✨</span>
          pylinka <span class="text-muted-foreground">playground</span>
        </a>
        <span id="fps" class="font-mono text-xs text-muted-foreground">—</span>
      </div>

      <div class="overflow-hidden rounded-xl border border-border bg-black">
        <canvas id="stage" class="block w-full" style="height: 440px"></canvas>
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-4">
        <label class="flex items-center gap-2 text-sm text-muted-foreground">
          wind
          <input id="wind" type="range" min="0" max="240" value="0" class="w-40" />
          <span id="windv" class="w-10 font-mono text-xs">0</span>
        </label>
        <label class="flex items-center gap-2 text-sm text-muted-foreground">
          orbit
          <input id="orbit" type="checkbox" checked />
        </label>
        <button id="burst" class="rounded-md border border-border px-3 py-1.5 text-sm hover:bg-accent">
          Burst
        </button>
        <span class="text-xs text-muted-foreground">move your mouse over the canvas</span>
      </div>

      <p class="mt-4 text-sm text-muted-foreground">
        Live WebGL2 transform-feedback simulation from <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">@pylinka/core/webgl</code>.
        The emitter orbits (world-space, §14.5): sparks hang and fade behind it. Drag the wind knob —
        it updates with zero recompilation.
      </p>
    </main>

    <script>
      import { createParticles } from '@pylinka/core/webgl';

      const project = {
        format: 'pylinka/v1', version: 1, catalogVersion: 1,
        id: 'demo', name: 'Coin Spark Trail',
        createdAt: '2026-07-10T00:00:00Z', updatedAt: '2026-07-10T00:00:00Z',
        params: [
          { id: 'p1', name: 'windPower', type: 'f32', min: 0, max: 240, scale: 'linear', default: { t: 'f32', v: 0 } },
          { id: 'p2', name: 'windDir', type: 'f32', min: -3.14159, max: 3.14159, scale: 'linear', default: { t: 'f32', v: 0 } },
        ],
        assets: [],
        systems: [{
          id: 's1', name: 'sparks', capacity: 6000, blendMode: 'add', enabled: true, space: 'world',
          emitter: { mode: 'flow', rate: 420, rateOverDistance: 1.4 },
          graph: {
            nodes: [
              { id: 'n1', kind: 'shape.point', values: { offset: { t: 'vec2', v: [0, 0] } } },
              { id: 'n2', kind: 'output.spawnPosition' },
              { id: 'n3', kind: 'gen.randomRange', values: { min: { t: 'f32', v: 0.6 }, max: { t: 'f32', v: 1.3 } } },
              { id: 'n4', kind: 'output.initLife' },
              { id: 'n5', kind: 'gen.randomVec2', values: { min: { t: 'vec2', v: [-45, -150] }, max: { t: 'vec2', v: [45, -240] } } },
              { id: 'n6', kind: 'output.initVelocity' },
              { id: 'n7', kind: 'field.gravity', values: { g: { t: 'vec2', v: [0, 340] } } },
              { id: 'n8', kind: 'output.addForce' },
              { id: 'n9', kind: 'param.ref', structural: { param: 'p1' } },
              { id: 'n10', kind: 'param.ref', structural: { param: 'p2' } },
              { id: 'n11', kind: 'field.directional' },
              { id: 'n12', kind: 'output.addForce' },
              { id: 'n13', kind: 'gen.colorOverLife', structural: { ease: 'power2.out' }, values: { from: { t: 'color', v: '#ffd27aff' }, to: { t: 'color', v: '#ff3b0000' } } },
              { id: 'n14', kind: 'output.writeColor' },
              { id: 'n15', kind: 'gen.scaleOverLife', structural: { ease: 'power2.out' }, values: { from: { t: 'f32', v: 1.6 }, to: { t: 'f32', v: 0 } } },
              { id: 'n16', kind: 'output.writeScale' },
            ],
            edges: [
              { id: 'e1', from: { nodeId: 'n1', portId: 'pos' }, to: { nodeId: 'n2', portId: 'pos' } },
              { id: 'e2', from: { nodeId: 'n3', portId: 'out' }, to: { nodeId: 'n4', portId: 'life' } },
              { id: 'e3', from: { nodeId: 'n5', portId: 'out' }, to: { nodeId: 'n6', portId: 'vel' } },
              { id: 'e4', from: { nodeId: 'n7', portId: 'force' }, to: { nodeId: 'n8', portId: 'force' } },
              { id: 'e5', from: { nodeId: 'n9', portId: 'out' }, to: { nodeId: 'n11', portId: 'strength' } },
              { id: 'e6', from: { nodeId: 'n10', portId: 'out' }, to: { nodeId: 'n11', portId: 'angle' } },
              { id: 'e7', from: { nodeId: 'n11', portId: 'force' }, to: { nodeId: 'n12', portId: 'force' } },
              { id: 'e8', from: { nodeId: 'n13', portId: 'out' }, to: { nodeId: 'n14', portId: 'color' } },
              { id: 'e9', from: { nodeId: 'n15', portId: 'out' }, to: { nodeId: 'n16', portId: 'scale' } },
            ],
          },
        }],
      };

      const canvas = document.getElementById('stage');
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      function resize() {
        canvas.width = Math.floor(canvas.clientWidth * dpr);
        canvas.height = Math.floor(canvas.clientHeight * dpr);
      }
      resize();
      window.addEventListener('resize', resize);

      const fx = createParticles(canvas, project);

      let orbit = true;
      let mouse = null;
      canvas.addEventListener('pointermove', (e) => {
        const r = canvas.getBoundingClientRect();
        mouse = [(e.clientX - r.left) * dpr, (e.clientY - r.top) * dpr];
      });
      canvas.addEventListener('pointerleave', () => { mouse = null; });

      document.getElementById('orbit').addEventListener('change', (e) => { orbit = e.target.checked; });
      const windEl = document.getElementById('wind');
      const windv = document.getElementById('windv');
      windEl.addEventListener('input', () => {
        fx.setKnob('windPower', +windEl.value);
        fx.setKnob('windDir', 0);
        windv.textContent = windEl.value;
      });
      document.getElementById('burst').addEventListener('click', () => fx.spawnBurst(400));

      const fpsEl = document.getElementById('fps');
      let last = performance.now();
      let acc = 0, frames = 0, t = 0;
      function frame(now) {
        const dt = Math.min((now - last) / 1000, 0.05);
        last = now;
        t += dt;
        if (mouse) {
          fx.setEmitter(mouse[0], mouse[1]);
        } else if (orbit) {
          const cx = canvas.width / 2, cy = canvas.height / 2;
          const rad = Math.min(canvas.width, canvas.height) * 0.28;
          fx.setEmitter(cx + Math.cos(t * 1.8) * rad, cy + Math.sin(t * 1.8) * rad);
        } else {
          fx.setEmitter(canvas.width / 2, canvas.height / 2);
        }
        fx.update(dt);
        acc += dt; frames++;
        if (acc >= 0.5) {
          fpsEl.textContent = Math.round(frames / acc) + ' fps · ' + fx.aliveCount().toLocaleString() + ' alive';
          acc = 0; frames = 0;
        }
        requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    </script>
  </body>
</html>
