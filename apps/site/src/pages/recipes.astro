---
import '../styles/global.css';
import Head from '../components/Head.astro';
import { RECIPES } from '../recipes/data';

const groups = ['all', 'trails', 'fire', 'magic', 'ambient', 'ui', 'abstract', 'swirl', 'drawn', 'combo'];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <Head
      title={`Pylinka Recipes — ${RECIPES.length} ready-made GPU particle effects for PixiJS`}
      description={`A gallery of ${RECIPES.length} open-source particle effects for PixiJS — trails, fire, magic, ambient, UI, abstract, swirling vortexes, drawn emission areas, and multi-emitter combos. Each is a real pylinka project you can open in the editor and tweak live.`}
      path="/recipes"
    />
  </head>
  <body>
    <header class="sticky top-0 z-40 border-b border-border bg-background/80 backdrop-blur">
      <div class="mx-auto flex h-14 max-w-6xl items-center gap-3 px-5">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <span class="grid h-6 w-6 place-items-center rounded-md border border-border bg-card text-[11px]">✨</span>
          pylinka
        </a>
        <span class="text-sm text-muted-foreground">recipes</span>
        <a href="/editor" class="ml-auto text-sm text-muted-foreground hover:text-foreground">Editor →</a>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-5 py-8">
      <h1 class="text-2xl font-semibold tracking-tight">Recipes</h1>
      <p class="mt-1 text-sm text-muted-foreground">
        {RECIPES.length} effects, each a real pylinka project. Open any in the editor to tweak it live.
      </p>

      <div id="filters" class="mt-5 flex flex-wrap gap-2">
        {
          groups.map((g) => (
            <button data-group={g} class:list={['filter rounded-full border border-border px-3 py-1 text-xs text-muted-foreground transition-colors hover:text-foreground', g === 'all' && 'active']}>
              {g}
            </button>
          ))
        }
      </div>

      <div id="grid" class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          RECIPES.map((r) => (
            <div class="recipe-card overflow-hidden rounded-xl border border-border bg-card" data-group={r.group}>
              <div class="relative bg-black" style="height: 150px">
                <video
                  data-video
                  class="h-full w-full object-cover"
                  muted
                  loop
                  playsinline
                  preload="none"
                  poster={`/recipes/${r.slug}/card.jpg`}
                >
                  <source src={`/recipes/${r.slug}/card.webm`} type="video/webm" />
                </video>
                <span class="absolute right-2 top-2 rounded-full border border-border bg-background/80 px-2 py-0.5 text-[10px] text-muted-foreground backdrop-blur">
                  {r.group}
                </span>
              </div>
              <div class="p-3">
                <h3 class="text-sm font-medium">{r.title}</h3>
                <p class="mt-0.5 text-xs text-muted-foreground">{r.oneLiner}</p>
                <div class="mt-2 flex flex-wrap gap-1">
                  {r.tags.map((t) => (
                    <code class="rounded border border-border px-1.5 py-0.5 font-mono text-[9px] text-muted-foreground">{t}</code>
                  ))}
                </div>
                <a
                  href={`/editor?recipe=${r.slug}`}
                  class="mt-3 flex items-center justify-center rounded-md border border-border py-1.5 text-xs text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
                >
                  Open in editor →
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </main>

    <script>
      // Play only on-screen videos (autoplaying 44 at once wastes CPU).
      const io = new IntersectionObserver(
        (entries) => {
          for (const en of entries) {
            const v = en.target as HTMLVideoElement;
            if (en.isIntersecting) v.play().catch(() => {});
            else v.pause();
          }
        },
        { rootMargin: '150px' },
      );
      document.querySelectorAll<HTMLVideoElement>('video[data-video]').forEach((v) => io.observe(v));

      const grid = document.getElementById('grid')!;
      document.querySelectorAll('.filter').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.filter').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          const g = (btn as HTMLElement).dataset.group!;
          grid.querySelectorAll<HTMLElement>('.recipe-card').forEach((card) => {
            card.style.display = g === 'all' || card.dataset.group === g ? '' : 'none';
          });
        });
      });
    </script>

    <style>
      .filter.active {
        color: var(--color-foreground);
        background: var(--color-accent);
      }
    </style>
  </body>
</html>
