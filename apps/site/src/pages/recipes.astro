---
import DocsLayout from '../layouts/DocsLayout.astro';

const recipes = [
  {
    slug: 'coin-spark-trail',
    title: 'Coin Spark Trail',
    group: 'trails',
    oneLiner: 'World-space sparks that hang behind a flying coin, with a live wind knob.',
    apis: ['shape.point', 'gen.randomVec2', 'field.gravity', 'field.directional', 'gen.colorOverLife'],
  },
];
---

<DocsLayout title="Pylinka — Recipes" active="recipes">
  <h1>Recipes</h1>
  <p class="!text-base !text-muted-foreground">
    Worked examples you can open in the editor and fork. Live previews light up once the editor and
    preview pipeline ship.
  </p>

  <div class="not-prose mt-6 grid gap-4 sm:grid-cols-2">
    {
      recipes.map((r) => (
        <div class="overflow-hidden rounded-xl border border-border bg-card">
          <div class="relative grid h-36 place-items-center border-b border-border bg-muted/30">
            <span class="text-sm text-muted-foreground">✨ preview coming soon</span>
            <span class="absolute right-3 top-3 rounded border border-border bg-background px-2 py-0.5 text-[10px] text-muted-foreground">
              {r.group}
            </span>
          </div>
          <div class="p-4">
            <h3 class="font-medium">{r.title}</h3>
            <p class="mt-1 text-sm text-muted-foreground">{r.oneLiner}</p>
            <div class="mt-3 flex flex-wrap gap-1.5">
              {r.apis.map((a) => (
                <code class="rounded border border-border px-1.5 py-0.5 font-mono text-[10px] text-muted-foreground">
                  {a}
                </code>
              ))}
            </div>
          </div>
        </div>
      ))
    }
    <div class="grid place-items-center rounded-xl border border-dashed border-border p-6 text-center text-sm text-muted-foreground">
      More recipes land with the editor.
    </div>
  </div>
</DocsLayout>
