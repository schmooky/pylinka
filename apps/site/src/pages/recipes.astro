---
import '../styles/global.css';
import { RECIPES } from '../recipes/data';

const groups = ['all', 'trails', 'fire', 'magic', 'ambient', 'ui', 'abstract'];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Pylinka — Recipes</title>
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%E2%9C%A8%3C/text%3E%3C/svg%3E" />
  </head>
  <body>
    <header class="sticky top-0 z-40 border-b border-border bg-background/80 backdrop-blur">
      <div class="mx-auto flex h-14 max-w-6xl items-center gap-3 px-5">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <span class="grid h-6 w-6 place-items-center rounded-md border border-border bg-card text-[11px]">✨</span>
          pylinka
        </a>
        <span class="text-sm text-muted-foreground">recipes</span>
        <a href="/playground" class="ml-auto text-sm text-muted-foreground hover:text-foreground">Playground →</a>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-5 py-8">
      <h1 class="text-2xl font-semibold tracking-tight">Recipes</h1>
      <p class="mt-1 text-sm text-muted-foreground">
        {RECIPES.length} effects, each a real pylinka project rendering live on WebGL2. Hover to see
        it react to your cursor.
      </p>

      <div id="filters" class="mt-5 flex flex-wrap gap-2">
        {
          groups.map((g) => (
            <button data-group={g} class:list={['filter rounded-full border border-border px-3 py-1 text-xs text-muted-foreground transition-colors hover:text-foreground', g === 'all' && 'active']}>
              {g}
            </button>
          ))
        }
      </div>

      <div id="grid" class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          RECIPES.map((r) => (
            <div class="recipe-card overflow-hidden rounded-xl border border-border bg-card" data-slug={r.slug} data-group={r.group}>
              <div class="relative bg-black" style="height: 150px">
                <canvas data-canvas={r.slug} class="block h-full w-full"></canvas>
                <span class="absolute right-2 top-2 rounded-full border border-border bg-background/80 px-2 py-0.5 text-[10px] text-muted-foreground backdrop-blur">
                  {r.group}
                </span>
              </div>
              <div class="p-3">
                <h3 class="text-sm font-medium">{r.title}</h3>
                <p class="mt-0.5 text-xs text-muted-foreground">{r.oneLiner}</p>
                <div class="mt-2 flex flex-wrap gap-1">
                  {r.tags.map((t) => (
                    <code class="rounded border border-border px-1.5 py-0.5 font-mono text-[9px] text-muted-foreground">{t}</code>
                  ))}
                </div>
                <a
                  href={`/editor?recipe=${r.slug}`}
                  class="mt-3 flex items-center justify-center rounded-md border border-border py-1.5 text-xs text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
                >
                  Open in editor →
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </main>

    <script>
      import { createParticles, type ParticlesHandle } from '@pylinka/core/webgl';
      import { RECIPES } from '../recipes/data';

      const bySlug = new Map(RECIPES.map((r) => [r.slug, r]));
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      const MAX_ACTIVE = 12;

      interface Live {
        fx: ParticlesHandle;
        group: string;
        canvas: HTMLCanvasElement;
        t: number;
        mouse: [number, number] | null;
      }
      const active = new Map<string, Live>();

      function start(canvas: HTMLCanvasElement) {
        const slug = canvas.dataset.canvas!;
        if (active.has(slug) || active.size >= MAX_ACTIVE) return;
        const recipe = bySlug.get(slug);
        if (!recipe) return;
        canvas.width = Math.floor(canvas.clientWidth * dpr);
        canvas.height = Math.floor(canvas.clientHeight * dpr);
        let fx: ParticlesHandle;
        try {
          fx = createParticles(canvas, recipe.project, { zoom: 1.8, sizeScale: 2.4 });
        } catch {
          return;
        }
        const live: Live = { fx, group: recipe.group, canvas, t: Math.random() * 6, mouse: null };
        canvas.onpointermove = (e) => {
          const r = canvas.getBoundingClientRect();
          live.mouse = [(e.clientX - r.left) * dpr, (e.clientY - r.top) * dpr];
        };
        canvas.onpointerleave = () => (live.mouse = null);
        active.set(slug, live);
      }

      function stop(slug: string) {
        const live = active.get(slug);
        if (!live) return;
        live.fx.destroy();
        active.delete(slug);
      }

      const io = new IntersectionObserver(
        (entries) => {
          for (const en of entries) {
            const card = en.target as HTMLElement;
            const canvas = card.querySelector('canvas') as HTMLCanvasElement;
            if (en.isIntersecting) start(canvas);
            else stop(canvas.dataset.canvas!);
          }
        },
        { rootMargin: '120px' },
      );
      document.querySelectorAll('.recipe-card').forEach((c) => io.observe(c));

      let last = performance.now();
      function frame(now: number) {
        const dt = Math.min((now - last) / 1000, 0.05);
        last = now;
        for (const live of active.values()) {
          const { fx, canvas } = live;
          live.t += dt;
          const cx = canvas.width / 2;
          const cy = canvas.height / 2;
          if (live.mouse) fx.setEmitter(live.mouse[0], live.mouse[1]);
          else if (live.group === 'trails') {
            const r = Math.min(canvas.width, canvas.height) * 0.3;
            fx.setEmitter(cx + Math.cos(live.t * 1.6) * r, cy + Math.sin(live.t * 1.6) * r);
          } else if (live.group === 'ambient') fx.setEmitter(cx, canvas.height * 0.12);
          else fx.setEmitter(cx, cy);
          fx.update(dt);
        }
        requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);

      // group filter
      const grid = document.getElementById('grid')!;
      document.querySelectorAll('.filter').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.filter').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          const g = (btn as HTMLElement).dataset.group!;
          grid.querySelectorAll<HTMLElement>('.recipe-card').forEach((card) => {
            card.style.display = g === 'all' || card.dataset.group === g ? '' : 'none';
          });
        });
      });
    </script>

    <style>
      .filter.active {
        color: var(--color-foreground);
        background: var(--color-accent);
      }
    </style>
  </body>
</html>
