---
import Base from '../layouts/Base.astro';

// §9 recipe gallery. The catalog will move to Astro content collections
// (apps/site/src/content/recipes/*.mdx) once @pylinka/core can mount <RecipeDemo/>.
const recipes = [
  {
    slug: 'coin-spark-trail',
    title: 'Coin Spark Trail',
    group: 'trails',
    oneLiner: "World-space sparks that hang behind a flying coin, with a live wind knob.",
    apis: ['shape.point', 'gen.randomVec2', 'field.gravity', 'field.directional', 'param.ref', 'gen.colorOverLife'],
    ready: false,
  },
];

const groups = ['trails', 'fire', 'magic', 'ambient', 'ui', 'abstract'];
---

<Base title="Pylinka — Recipes" active="recipes">
  <section class="py-14">
    <h1 class="text-3xl font-semibold tracking-tight">Recipes</h1>
    <p class="mt-2 max-w-2xl text-[var(--color-fg-muted)]">
      Curated example projects with generated preview clips and an "Open in editor" fork. Live demos
      light up once <code class="font-mono text-xs text-[var(--color-violet-bright)]">@pylinka/core</code> ships.
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {
        groups.map((g) => (
          <span class="rounded-full border border-[var(--color-border)] bg-[var(--color-surface-2)] px-3 py-1 text-xs text-[var(--color-fg-muted)]">
            {g}
          </span>
        ))
      }
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        recipes.map((r) => (
          <div class="group overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]/50 transition-colors hover:border-[var(--color-violet)]/40">
            <div class="relative grid h-40 place-items-center overflow-hidden border-b border-[var(--color-border)] bg-gradient-to-br from-[var(--color-surface-2)] to-[var(--color-bg)]">
              <div class="grid-fade absolute inset-0 opacity-40"></div>
              <div class="relative flex items-center gap-2 text-sm text-[var(--color-fg-dim)]">
                <span class="text-2xl">✨</span> preview coming soon
              </div>
              <span class="absolute right-3 top-3 rounded-full bg-[var(--color-violet)]/15 px-2 py-0.5 text-[10px] font-medium text-[var(--color-violet-bright)]">
                {r.group}
              </span>
            </div>
            <div class="p-5">
              <h3 class="font-medium">{r.title}</h3>
              <p class="mt-1 text-sm text-[var(--color-fg-muted)]">{r.oneLiner}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {r.apis.slice(0, 4).map((a) => (
                  <code class="rounded bg-[var(--color-surface-2)] px-1.5 py-0.5 font-mono text-[10px] text-[var(--color-cyan)]">
                    {a}
                  </code>
                ))}
              </div>
            </div>
          </div>
        ))
      }

      <div class="grid place-items-center rounded-2xl border border-dashed border-[var(--color-border)] p-8 text-center text-sm text-[var(--color-fg-dim)]">
        More recipes land with the editor & preview pipeline (M1-beta).
      </div>
    </div>
  </section>
</Base>
