{
  "name": "@pylinka/core",
  "version": "0.1.0",
  "description": "Pylinka runtime: WebGL2 transform-feedback particle engine (createParticles), CPU scheduler, knob bus with live-uniform updates, and a pixi.js v8 render pipe. WebGPU compute backend planned.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schmooky/pylinka.git",
    "directory": "packages/core"
  },
  "homepage": "https://pylinka.schmooky.dev",
  "bugs": "https://github.com/schmooky/pylinka/issues",
  "keywords": [
    "particles",
    "particle-system",
    "gpu",
    "pixijs",
    "pixi",
    "webgl2",
    "webgpu",
    "vfx",
    "game",
    "slot",
    "node-editor",
    "dataflow",
    "runtime",
    "transform-feedback",
    "renderer"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pixi": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js"
    },
    "./webgl": {
      "types": "./dist/webgl/index.d.ts",
      "import": "./dist/webgl/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pylinka/graph": "workspace:*",
    "@pylinka/compiler": "workspace:*"
  },
  "devDependencies": {
    "pixi.js": "^8"
  },
  "peerDependencies": {
    "pixi.js": "^8"
  },
  "peerDependenciesMeta": {
    "pixi.js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
