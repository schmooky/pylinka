{
  "name": "@pylinka/core",
  "version": "0.0.0",
  "description": "Pylinka runtime. CPU scheduling, knob bus, and (WIP) WebGPU simulation/render backends.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pixi": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js"
    },
    "./webgl": {
      "types": "./dist/webgl/index.d.ts",
      "import": "./dist/webgl/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pylinka/graph": "workspace:*",
    "@pylinka/compiler": "workspace:*"
  },
  "devDependencies": {
    "pixi.js": "^8"
  },
  "peerDependencies": {
    "pixi.js": "^8"
  },
  "peerDependenciesMeta": {
    "pixi.js": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  }
}
