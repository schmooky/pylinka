{
  "name": "@pylinka/format",
  "version": "0.1.0",
  "description": "Pylinka project format: parse, serialize (inline↔blob assets), and migrate documents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schmooky/pylinka.git",
    "directory": "packages/format"
  },
  "homepage": "https://pylinka.schmooky.dev",
  "bugs": "https://github.com/schmooky/pylinka/issues",
  "keywords": [
    "particles",
    "particle-system",
    "gpu",
    "pixijs",
    "pixi",
    "webgl2",
    "webgpu",
    "vfx",
    "game",
    "slot",
    "node-editor",
    "dataflow",
    "serialization",
    "file-format",
    "migration"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pylinka/graph": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
